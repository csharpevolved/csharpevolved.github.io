<!doctype html>
<html lang="en">
  <head>
    {% set pageTitle = site.title if page.url == "/" else (title or site.name) %}
    {% set documentTitle = pageTitle if page.url == "/" else pageTitle + " | " + site.name %}
    {% set pageDescription = site.stripMarkdown(description or (feature and feature.summary) or site.description) %}
    {% set pageUrl = site.absoluteUrl(page.url) %}
    {% set pageImage = site.absoluteUrl(image or (feature and feature.image) or site.defaultSocialImage) %}
    {% set openGraphType = "article" if feature else "website" %}
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ documentTitle }}</title>
    <meta name="description" content="{{ pageDescription }}" />
    <link rel="canonical" href="{{ pageUrl }}" />
    <meta property="og:title" content="{{ pageTitle }}" />
    <meta property="og:description" content="{{ pageDescription }}" />
    <meta property="og:type" content="{{ openGraphType }}" />
    <meta property="og:url" content="{{ pageUrl }}" />
    <meta property="og:image" content="{{ pageImage }}" />
    <meta property="og:site_name" content="{{ site.name }}" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="{{ pageTitle }}" />
    <meta name="twitter:description" content="{{ pageDescription }}" />
    <meta name="twitter:image" content="{{ pageImage }}" />
    {% if site.twitter %}
    <meta name="twitter:site" content="{{ site.twitter }}" />
    {% endif %}
    {% include "structured-data.njk" %}
    <link rel="stylesheet" href="/assets/site.css" />
  </head>
  <body id="top">
    <div class="corner-badge" aria-hidden="true">In development</div>
    <header class="site-header">
      <div class="container nav">
        <a class="brand" href="/">{{ site.name }}</a>
        <nav aria-label="Primary">
          <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/features/">Features</a></li>
            <li><a href="/cloud/">Cloud</a></li>
            <li><a href="/toolbox/">Toolbox</a></li>
          </ul>
        </nav>
      </div>
    </header>
    <main class="container">
      {{ content | safe }}
    </main>
    <footer class="site-footer">
      <div class="container footer-meta">
        <p>Built for developers tracking C# language evolution.</p>
        <a class="footer-meta-link" href="https://github.com/csharpevolved/csharpevolved.github.io" target="_blank" title="View source on GitHub">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 18 18" style="vertical-align: middle;">
              <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8"/>
            </svg>
            <span class="visible-mobile">GitHub</span>
        </a>
      </div>
    </footer>
  </body>
</html>
